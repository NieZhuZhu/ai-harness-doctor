{
  "name": "ai-harness-doctor",
  "version": "0.3.0",
  "description": "AI Harness Doctor ‚Äî audit, consolidate & guard your repo's AI agent configs (AGENTS.md, CLAUDE.md, .cursorrules, ...) with a checkup‚Üítreat‚Üífollow-up‚Üíefficacy pipeline",
  "bin": {
    "ai-harness-doctor": "bin/cli.js"
  },
  "files": [
    "bin",
    "!bin/*.test.js",
    "scripts/*.py",
    "!scripts/check_readme_sync.py",
    "!scripts/gen_adapters.py",
    "commands",
    "adapters",
    "references",
    "assets",
    "assets/agent-tools.json",
    "SKILL.md",
    "README.md",
    "README.zh-CN.md",
    "README.ja.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=16"
  },
  "keywords": [
    "ai-harness",
    "harness",
    "agents-md",
    "AGENTS.md",
    "claude-code",
    "claude",
    "skill",
    "ai-agents",
    "agent-config",
    "llm-config",
    "cursor",
    "codex",
    "gemini-cli",
    "drift",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NieZhuZhu/ai-harness-doctor.git"
  },
  "homepage": "https://github.com/NieZhuZhu/ai-harness-doctor#readme",
  "bugs": {
    "url": "https://github.com/NieZhuZhu/ai-harness-doctor/issues"
  },
  "author": "NieZhuZhu",
  "license": "MIT",
  "scripts": {
    "test": "python3 -m unittest discover -s tests && node --test bin/*.test.js",
    "test:py": "python3 -m unittest discover -s tests",
    "test:js": "node --test bin/*.test.js",
    "coverage": "npm run coverage:py && npm run coverage:js",
    "coverage:py": "python3 -m coverage run -m unittest discover -s tests && python3 -m coverage report",
    "coverage:js": "node --test --experimental-test-coverage bin/*.test.js",
    "check": "npm run lint && npm test",
    "lint": "npm run lint:js && npm run lint:py && npm run lint:docs && npm run lint:adapters",
    "lint:js": "eslint bin",
    "lint:py": "ruff check scripts tests",
    "lint:docs": "python3 scripts/check_readme_sync.py",
    "lint:adapters": "python3 scripts/gen_adapters.py --check",
    "gen:adapters": "python3 scripts/gen_adapters.py",
    "format": "prettier --write .",
    "format:py": "ruff format scripts tests"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4"
  }
}
